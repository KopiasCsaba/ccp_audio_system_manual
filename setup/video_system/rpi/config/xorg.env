# X11 environment variables
# For systemd EnvironmentFile: no 'export' keyword
# For shell sourcing: use 'set -a' before sourcing or add 'export' when sourcing

# For user applications (non-root)
XDG_RUNTIME_DIR=/run/user/1000

# DISPLAY variable (unified desktop spanning both displays)
# Both apps use DISPLAY=:0 and position themselves via window geometry
# HDMI-1 (left): position 0,0 (1920x1080)
# HDMI-2 (right): position 1920,0 (1920x1080)
DISPLAY=:0

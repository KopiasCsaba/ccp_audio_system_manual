[Unit]
Description=Keyboard Input Monitor
After=xorg.service
Requires=xorg.service
PartOf=graphical.target

[Service]
Type=simple
User=ccpadmin
# Need to add user to input group for device access
SupplementaryGroups=input
ExecStart=/usr/bin/python3 /config/keys.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=graphical.target
